{
  "expectation_suite_name": "inventory_status",
  "ge_cloud_id": null,
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Expectations for inventory status data aligned with Product schema"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_set",
      "kwargs": {
        "column_set": [
          "product_id", "name", "category",
          "unit_cost", "selling_price", "lead_time_days",
          "min_order_qty", "current_stock",
          "reorder_point", "safety_stock",
          "daily_demand_avg", "daily_demand_std"
        ],
        "exact_match": false
      },
      "meta": {
        "notes": "Columns aligned with Product schema in schemas.py"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "product_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "current_stock"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "current_stock",
        "min_value": 0,
        "max_value": null,
        "strict_min": false
      },
      "meta": {
        "notes": "Inventory stock must be non-negative"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "reorder_point",
        "min_value": 0,
        "max_value": null
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "safety_stock",
        "min_value": 0,
        "max_value": null
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "lead_time_days",
        "min_value": 0,
        "max_value": 365
      },
      "meta": {
        "notes": "Lead time must be between 0 and 365 days"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "unit_cost",
        "min_value": 0.01,
        "max_value": null,
        "strict_min": false
      },
      "meta": {
        "notes": "Unit cost must be positive"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "product_id",
        "regex": "^[A-Z]{2,4}-\\d{3,6}$"
      }
    },
    {
      "expectation_type": "expect_column_distinct_values_to_be_in_set",
      "kwargs": {
        "column": "category",
        "value_set": ["electronics", "food", "pharma", "industrial", "apparel"]
      },
      "meta": {
        "notes": "Must match ProductCategory enum values"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {
        "column": "product_id"
      },
      "meta": {
        "notes": "Each product must be unique"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": null
      }
    }
  ]
}
