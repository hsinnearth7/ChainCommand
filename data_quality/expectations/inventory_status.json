{
  "expectation_suite_name": "inventory_status",
  "ge_cloud_id": null,
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Expectations for inventory status data"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_set",
      "kwargs": {
        "column_set": [
          "product_id", "warehouse_id", "quantity_on_hand",
          "reorder_point", "safety_stock", "lead_time_days",
          "unit_cost", "last_updated"
        ],
        "exact_match": false
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "product_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "warehouse_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "quantity_on_hand"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "quantity_on_hand",
        "min_value": 0,
        "max_value": null,
        "strict_min": false
      },
      "meta": {
        "notes": "Inventory quantity must be non-negative"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "reorder_point",
        "min_value": 0,
        "max_value": null
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "safety_stock",
        "min_value": 0,
        "max_value": null
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "lead_time_days",
        "min_value": 0,
        "max_value": 365
      },
      "meta": {
        "notes": "Lead time must be between 0 and 365 days"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "unit_cost",
        "min_value": 0.01,
        "max_value": null,
        "strict_min": false
      },
      "meta": {
        "notes": "Unit cost must be positive"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "product_id",
        "regex": "^[A-Z]{2,4}-\\d{3,6}$"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "warehouse_id",
        "regex": "^WH-\\d{2,4}$"
      }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": {
        "column_list": ["product_id", "warehouse_id"]
      },
      "meta": {
        "notes": "Each product-warehouse combination must be unique"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": null
      }
    }
  ]
}
